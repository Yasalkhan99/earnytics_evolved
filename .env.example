# Copy to .env.local for local dev. On Vercel: Project → Settings → Environment Variables (Production).

# Site URL for short links (/go/short/...) — MUST be production domain on live, not localhost
NEXT_PUBLIC_APP_URL=https://earnytics.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Linkhexa Partner API (required for brands sync, tracking links, transactions)
LINKHEXA_API_KEY=lh_live_your_key_here
LINKHEXA_API_BASE_URL=https://www.linkhexa.com

# Other networks (add same values as .env.local)
IMPACT_ACCOUNT_SID=
IMPACT_AUTH_TOKEN=
ADMITAD_CLIENT_ID=
ADMITAD_CLIENT_SECRET=
ADMITAD_BASE64_HEADER=
ADMITAD_PUBLISHER_CODE=
YIELDKIT_API_KEY=
YIELDKIT_API_SECRET=
YIELDKIT_SITE_ID=
YIELDKIT_DOMAIN=
